DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
ALLOWED_USER_IDS=123456789,987654321
BASE_PROJECT_DIR=/Users/you/projects
RATE_LIMIT_PER_MINUTE=10
# Show estimated API cost in task results (set false for Max plan users)
SHOW_COST=true

# --- Coder workspace integration ---
# SSH suffix appended to workspace name to form the SSH hostname (requires `coder config-ssh`)
# CODER_SSH_SUFFIX=.coder
# Base home directory inside each Coder workspace
# CODER_REMOTE_HOME=/home/coder

# --- Claude Code OAuth token (subscription mode) ---
# Long-lived OAuth token for Claude Code subscription accounts.
# Passed as CLAUDE_CODE_OAUTH_TOKEN to the claude process, and used by /usage to query the API.
# OAUTH_TOKEN=your-oauth-token-here

# --- Model selection (used by /model command in subscription mode) ---
# Format: display_name:model_id,display_name:model_id,...
# AVAILABLE_MODELS=sonnet:claude-sonnet-4-5-20250929,opus:claude-opus-4-20250514,haiku:claude-haiku-4-5-20251001

# --- API Key mode env vars (used when /auth-mode api_key is set for a channel) ---
# Set these if you use a custom API endpoint or third-party proxy instead of Claude subscription
# ANTHROPIC_BASE_URL=https://your-proxy.example.com
# ANTHROPIC_AUTH_TOKEN=your-api-key-or-token
# ANTHROPIC_MODEL=claude-sonnet-4-6
# ANTHROPIC_DEFAULT_SONNET_MODEL=claude-sonnet-4-6
# ANTHROPIC_SMALL_FAST_MODEL=claude-haiku-4-5-20251001
# ANTHROPIC_DEFAULT_HAIKU_MODEL=claude-haiku-4-5-20251001
# DISABLE_NON_ESSENTIAL_MODEL_CALLS=1
# CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1
