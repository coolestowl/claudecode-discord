DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
ALLOWED_USER_IDS=123456789,987654321
BASE_PROJECT_DIR=/Users/you/projects
RATE_LIMIT_PER_MINUTE=10
# Show estimated API cost in task results (set false for Max plan users)
SHOW_COST=true

# --- API Key mode env vars (used when /auth-mode api_key is set for a channel) ---
